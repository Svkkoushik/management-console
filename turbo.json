{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "lint": {},
    "format": {},
    "dev": {
      "dependsOn": ["//#start:docker"],
      "persistent": true,
      "cache": false
    },
    "//#start:docker": {}
  }
}
